# ==============================================================
# Balance — かわいい家計簿  環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local
# ==============================================================

# --------------------------------------------------------------
# Supabase
# https://supabase.com/dashboard → Project Settings > API
# --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------------------------
# Auth0
# https://manage.auth0.com → Applications > your app > Settings
# --------------------------------------------------------------
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# 32文字以上のランダム文字列: openssl rand -hex 32
AUTH0_SECRET=
# ローカル: http://localhost:3000 / 本番: Cloud RunやVercelのURL
APP_BASE_URL=http://localhost:3000

# --------------------------------------------------------------
# AI プロバイダー
# --------------------------------------------------------------
# https://console.anthropic.com
ANTHROPIC_API_KEY=
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --------------------------------------------------------------
# LINE Login（任意）
# https://developers.line.biz → Providers > your channel
# --------------------------------------------------------------
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# --------------------------------------------------------------
# メール送信（お問い合わせ・パスワードリセット）
# https://resend.com/api-keys
# --------------------------------------------------------------
RESEND_API_KEY=

# --------------------------------------------------------------
# Google Maps
# https://console.cloud.google.com → APIとサービス > 認証情報
# 有効にするAPI: Places API (New), Geocoding API, Maps Static API
# --------------------------------------------------------------
# サーバーサイド（Places API / Geocoding）— IPアドレス制限推奨
GOOGLE_MAPS_API_KEY=
# クライアントサイド（Static Maps 地図画像）— HTTPリファラー制限を設定すること
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --------------------------------------------------------------
# 機能フラグ（デモ環境用。本番は設定不要）
# --------------------------------------------------------------
NEXT_PUBLIC_ENABLE_LINE_LOGIN=true
NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN=true

# デモアカウント（デモ環境のみ設定）
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=
